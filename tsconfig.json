{
    "compilerOptions": {
      "target": "es6",
      "module": "commonjs",
      "outDir": "dist",
      "sourceMap": false,
      "declaration": true,
      "lib": [
        "es2017.object",
        "es2015",
        "es2017",
        "dom"
      ],
    "typeRoots": [
      "./node_modules/@types",
      "./src/types"
    ],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
    },
    "files": [
      "./node_modules/@types/node/index.d.ts",
      "./src/types/express.d.ts"
    ],
    "include": [
      "src/**/*.ts",
      "package.json"
, "src/init/dummy.js"    ],
    "exclude": [
      "node_modules"
    ]
  }
